@import url("https://fonts.googleapis.com/css2?family=Sono:wght,MONO@200..800,1&display=swap");

@keyframes unblur-bg {
    from {
	backdrop-filter: blur(20px);
    }

    to {
	backdrop-filter: blur(3px);
    }
}

@keyframes unblur-fg
{
    from {
	filter: blur(10px);
    }

    to {
	filter: blur(0px);
    }
}

@keyframes blur-out {
    from {
	backdrop-filter: blur(3px) brightness(1);
	filter: brightness(1);
    }

    to {
	backdrop-filter: blur(3px) brightness(0);
	filter: brightness(0);
    }
}


body {
    position: absolute;
    width: 100%;
    height: 100%;
    margin: 0;
    
    display: flex;
    flex-direction: column;
    flex-wrap: nowrap;
    justify-content: center;
    align-items: center;

    font-family: "Sono";
    font-size: 16pt;
    
    background-image: url("../img/website_empty_bg_crop.png");
    background-repeat: no-repeat;
    background-attachment: fixed;
    background-size: cover;

    animation-name: unblur-bg, unblur-fg;
    animation-fill-mode: forwards, forwards;
    animation-duration: 3s, 2s;
}

body.blur-out {
    animation: blur-out 1s forwards;
}

.index_menu {
    margin-top: 25px;
    width: 10em;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5em;
}

.index_menu p {
    margin: 0px;
}

.index_menu button {
    background-color: transparent;
    border: none;

    font-family: "Sono";
    font-size: 13pt;
    cursor: pointer;
}

.index_menu hr {
    margin: 0px;
    width: 100%;
    
    border: none;
/*    border-top: 1px solid #ffffffff;*/
}
